<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.clashpow.helper</string>
    <key>MachServices</key>
    <dict>
        <key>com.clashpow.helper</key>
        <true/>
    </dict>
    <key>ProgramArguments</key>
    <array>
        <string>Contents/MacOS/com.clashpow.helper</string>
    </array>
    <key>SMAuthorizedClients</key>
    <array>
        <string>identifier "com.clashpow.app"</string>
    </array>
    <key>StandardOutPath</key>
    <string>/Library/Logs/ClashPow/com.clashpow.helper.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Library/Logs/ClashPow/com.clashpow.helper.err.log</string>
</dict>
</plist>
